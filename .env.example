# Email — Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=contact@balise-ia.fr
CONTACT_EMAIL=contact@balise-ia.fr

# Google Sheets — Lead capture (optionnel)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# Analytics (optionnel — activé uniquement si renseigné)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Microsoft Clarity — Heatmaps (optionnel)
NEXT_PUBLIC_CLARITY_ID=

# LinkedIn Insight Tag — Retargeting B2B (optionnel)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Rate limiting distribué — Upstash Redis (optionnel)
# Si non renseigné, le rate limiting utilise un Map en mémoire (suffisant pour une seule instance)
# Recommandé en production Vercel (multi-instances)
# Créer un compte sur https://upstash.com et copier les credentials
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
